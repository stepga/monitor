{
    "webui_address": "0.0.0.0:8899",
    "subsystems": ["listener", "cert", "stdout", "webui", "heartbeat", "diskmon"],
    "listener": {
        "address": "127.0.0.1:5566",
        "maxMsgSizeMB": 5
    },
    "diskThreshold": 0.8,
    "cert": {
        "minimum_days_left": 5,
        "check_interval_in_hours": 24,
        "urls": [
            "https://google.com",
            "https://example.com",
            "https://duckduckgo.com",
            "https://microsoft.com",
            "https://google.de",
            "https://expired.badssl.com",
            "https://reddit.com",
            "https://youtube.com"
        ]
    },
    "heartbeat": {
        "node_timeout_in_minutes": 90,
        "check_interval_in_minutes": 30
    }
}
