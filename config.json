{
    "reporter": ["stdout"],
    "collectors": ["listener", "cert"],
    "listener": {
        "address": "127.0.0.1:5566"
    },
    "cert": {
        "minimum_days_left": 5,
        "urls": [
            "https://google.com",
            "https://example.com",
            "https://duckduckgo.com",
            "https://microsoft.com",
            "https://google.de",
            "https://expired.badssl.com",
            "https://reddit.com",
            "https://youtube.com"
        ]
    }
}
